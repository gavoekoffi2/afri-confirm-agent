# ── Database ──
DATABASE_URL=postgresql://afri:afri_confirm_2024@postgres:5432/africonfirm

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── App ──
PORT=3002
NODE_ENV=production
APP_URL=https://confirm.votre-domaine.com
ADMIN_SECRET=votre-secret-admin-tres-long

# ── Twilio (OBLIGATOIRE) ──
# Créez un compte sur https://www.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx  # Votre numéro Twilio (ex: numéro virtuel CI/SN)

# ── OpenAI (pour analyse intent ambiguë) ──
OPENAI_API_KEY=sk-...

# ── ElevenLabs (optionnel, pour voix premium en français africain) ──
ELEVENLABS_API_KEY=

# ── Comportement des appels ──
CALL_DELAY_SECONDS=5        # Délai avant d'appeler après la commande
MAX_RETRY_ATTEMPTS=3        # Nombre de tentatives si pas de réponse
RETRY_DELAY_MINUTES=30      # Délai entre les tentatives

# ── Docker ──
POSTGRES_PASSWORD=afri_confirm_2024
DOMAIN=votre-domaine.com
